{
  "name": "notification-center",
  "version": "1.0.0",
  "description": "Unified Notification Center Backend - Multi-channel notification service with templates, queues, and tracking",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "migrate": "ts-node src/db/migrate.ts"
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "sql.js": "^1.10.3",
    "express": "^4.18.2",
    "handlebars": "^4.7.8",
    "ioredis": "^5.3.2",
    "prom-client": "^15.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "nock": "^13.4.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
